---
import "../styles/global.css";
import { socialLinks } from "../scripts/dummy";

const siteUrl = "https://portfolio.doannguyenlam.name.vn/";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Doan Nguyen Lam",
  alternateName: "Lam Doan",
  url: siteUrl,
  jobTitle: "Software Engineer",
  description: "Fullstack Developer specializing in Vue, React, Node.js, TypeScript, PostgreSQL.",
  sameAs: socialLinks.map((link) => link.url),
  knowsAbout: ["Vue.js", "React", "Node.js", "TypeScript", "PostgreSQL", "Fullstack Development", "Nuxt.js", "Laravel", "Spring Boot", "Docker", "AWS"],
  image: `${siteUrl}images/preview.jpeg`,
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Lam Doan - Software Engineer",
  description: "Portfolio of a Software Engineer specializing in Vue, React, Node.js, TypeScript, PostgreSQL.",
  url: siteUrl,
  author: {
    "@type": "Person",
    name: "Doan Nguyen Lam",
    jobTitle: "Software Engineer",
  },
  publisher: {
    "@type": "Person",
    name: "Doan Nguyen Lam",
  },
  inLanguage: "en",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="images/logo.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Lam Doan - Software Engineer</title>

    <!-- Meta tags for SEO -->
    <meta name="description" content="Fullstack Developer specializing in Vue, React, Node.js, TypeScript, PostgreSQL. Explore my projects, experience, and skills." />
    <meta name="keywords" content="fullstack developer, vue developer, react developer, node.js developer, typescript developer, portfolio, software engineer" />
    <meta name="author" content="Doan Nguyen Lam" />
    
    <meta name="robots" content="index, follow">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Meta tags for Open Graph -->
    <meta property="og:title" content="Doan Nguyen Lam - Software Engineer">
    <meta property="og:description" content="Portfolio of a Software Engineer specializing in Vue, React, Node.js, TypeScript, PostgreSQL">
    <meta property="og:image" content="https://portfolio.doannguyenlam.name.vn/images/preview.jpeg">
    <meta property="og:url" content="https://portfolio.doannguyenlam.name.vn/">
    <meta property="og:type" content="website">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Doan Nguyen Lam - Software Engineer">
    <meta name="twitter:description" content="Portfolio of a Software Engineer specializing in Vue, React, Node.js, TypeScript, PostgreSQL">
    <meta name="twitter:image" content="https://portfolio.doannguyenlam.name.vn/images/preview.jpeg">
    <meta name="twitter:url" content="https://portfolio.doannguyenlam.name.vn/">

    <!-- Meta tags for Google Search Console -->
    <meta name="google-site-verification" content="VHZoDbanalagWcf2z0THNALDceQfNAtkn4KFq7wICmg" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
  </head>
  <body class="bg-background text-main font-sans">
    <main class="mx-auto container space-y-16 px-4 md:px-8" id="main-content">
      <slot />
    </main>
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
  }

  body {
    line-height: 1.5;
    font-size: 16px;
    font-weight: 400;
    font-style: normal;
    font-stretch: normal;
    font-variant: normal;
    font-optical-sizing: auto;
  }
</style>

