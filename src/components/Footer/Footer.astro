---
import { socialLinks } from "../../scripts/dummy";
---

<footer class="footer-section bg-card-bg rounded-2xl p-8">
  <div class="grid grid-cols-3 gap-4 container mx-auto">
    <div class="left-side col-span-3 md:col-span-1">
      <h3 class="text-headline text-2xl font-bold text-center md:text-left">
        Lam Doan
      </h3>
    </div>
    <div class="center-side col-span-3 md:col-span-1">
      <p class="text-center text-paragraph md:text-left">
        Copyright 2026 Lam Doan
      </p>
    </div>
    <div class="right-side col-span-3 md:col-span-1">
      <ul class="flex items-center justify-center md:justify-end gap-4">
        {
          socialLinks.map((link) => (
            <li>
              <a href={link.url} target="_blank" rel="noopener noreferrer">
                <img src={link.icon} alt={link.name} class="w-6 h-6" />
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>
