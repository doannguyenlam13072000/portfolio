---
import { counters } from "../../scripts/dummy";
---

<section class="section-counter xl:mt-0 mt-32">
  <div
    class="mx-auto container grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4"
  >
    {
      counters.map((counter, i) => (
        <div class="col-span-1 bg-card-bg rounded-lg p-6">
          <div class="counter-item space-y-2">
            <h3 class="text-4xl font-bold">
              <span
                id={`counter-${i}`}
                data-end-val={counter.value}
                data-suffix={counter.suffix ?? ""}
              >
                0
              </span>
            </h3>
            <p class="text-lg font-light">{counter.title}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>

<script src="./index.js"></script>
