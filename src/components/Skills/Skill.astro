---
interface Props {
  name: string;
  image: string;
}
const { name, image } = Astro.props;
---

<div
  class="skill-item flex flex-col gap-2 items-center justify-center rounded-2xl bg-background w-24 h-24"
>
  <img class="w-10 h-10" src={image} alt={name} />
  <span class="text-sm font-semibold">{name}</span>
</div>
