---
const publicKey = import.meta.env.EMAILJS_PUBLIC_KEY ?? "";
const serviceId = import.meta.env.EMAILJS_SERVICE_ID ?? "";
const templateId = import.meta.env.EMAILJS_TEMPLATE_ID ?? "";

interface Props {
  id?: string;
}
const { id } = Astro.props;
---

<section
  id={id}
  class="contact-section container mx-auto max-w-full overflow-x-hidden px-4 sm:px-6 md:px-8"
>
  <div
    class="grid grid-cols-12 gap-4 sm:gap-6 md:gap-8 bg-card-bg rounded-2xl p-4 sm:p-6 md:p-8"
  >
    <div class="contact-header col-span-12 min-w-0">
      <h1
        class="text-2xl md:text-4xl font-bold text-headline my-3 md:my-4 text-center"
      >
        I'd love to hear from you!
      </h1>
      <p
        class="text-sm sm:text-base md:text-lg text-paragraph my-3 md:my-4 text-center max-w-xl mx-auto"
      >
        Whether you have a question or just want to say hi, I'll try my best to
        get back to you!
      </p>
    </div>

    <div
      class="contact-image-wrap col-span-12 md:col-span-6 flex items-center justify-center min-h-0 min-w-0"
    >
      <img
        src="/images/contact.svg"
        alt="Contact"
        class="w-full max-w-[280px] sm:max-w-md h-auto max-h-[200px] sm:max-h-[280px] md:max-h-[320px] object-contain"
      />
    </div>

    <div class="contact-form-wrap col-span-12 md:col-span-6 min-w-0">
      <form id="contact-form" class="space-y-3 sm:space-y-4 min-w-0 max-w-full">
        <div class="form-group min-w-0">
          <label
            for="name"
            class="block text-sm font-medium text-paragraph mb-1">Name</label
          >
          <input
            type="text"
            id="name"
            name="from_name"
            required
            class="w-full min-w-0 max-w-full p-2.5 sm:p-2 rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-headline text-base"
          />
        </div>
        <div class="form-group min-w-0">
          <label
            for="email"
            class="block text-sm font-medium text-paragraph mb-1">Email</label
          >
          <input
            type="email"
            id="email"
            name="from_email"
            required
            class="w-full min-w-0 max-w-full p-2.5 sm:p-2 rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-headline text-base"
          />
        </div>
        <div class="form-group min-w-0">
          <label
            for="message"
            class="block text-sm font-medium text-paragraph mb-1">Message</label
          >
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            class="w-full min-w-0 max-w-full p-2.5 sm:p-2 rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-headline resize-y text-base"
          ></textarea>
        </div>
        <p
          id="form-status"
          class="text-sm min-h-5 wrap-break-word"
          aria-live="polite"
        >
        </p>
        <button
          type="submit"
          id="submit-btn"
          class="w-full min-w-0 py-2.5 sm:py-2 px-4 rounded-md font-medium bg-headline text-card-bg hover:opacity-90 transition-opacity disabled:opacity-50 flex items-center justify-center gap-2 min-h-[44px] sm:min-h-[42px] cursor-pointer touch-manipulation"
        >
          <span id="submit-text">Send message</span>
          <span
            id="submit-spinner"
            class="loading-spinner hidden"
            aria-hidden="true"></span>
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-section .form-group input,
  .contact-section .form-group textarea {
    box-sizing: border-box;
  }
  .loading-spinner {
    width: 1.25rem;
    height: 1.25rem;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: contact-spin 0.6s linear infinite;
  }
  .loading-spinner:not(.hidden) {
    display: inline-block;
  }
  @keyframes contact-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script
  type="text/javascript"
  src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"
></script>

<script define:vars={{ publicKey, serviceId, templateId }}>
  (function initContactForm(publicKey, serviceId, templateId) {
    if (!publicKey || !serviceId || !templateId) {
      console.warn("EmailJS: Missing env config (VITE_APP_EMAILJS_*)");
      return;
    }
    if (typeof emailjs === "undefined") {
      console.warn("EmailJS: SDK not loaded.");
      return;
    }
    emailjs.init({ publicKey });
    const form = document.getElementById("contact-form");
    const statusEl = document.getElementById("form-status");
    const submitBtn = document.getElementById("submit-btn");
    const submitText = document.getElementById("submit-text");
    const submitSpinner = document.getElementById("submit-spinner");
    if (!form || !statusEl || !submitBtn || !submitText || !submitSpinner)
      return;

    function setLoading(loading) {
      submitBtn.disabled = loading;
      submitText.textContent = loading ? "Sending..." : "Send message";
      submitSpinner.classList.toggle("hidden", !loading);
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      statusEl.textContent = "";
      statusEl.classList.remove("text-green-600", "text-red-600");
      setLoading(true);
      try {
        await emailjs.sendForm(serviceId, templateId, form);
        statusEl.textContent = "Thanks! Your message was sent.";
        statusEl.classList.add("text-green-600");
        form.reset();
      } catch (err) {
        statusEl.textContent = "Something went wrong. Please try again.";
        statusEl.classList.add("text-red-600");
        console.error("EmailJS error:", err);
      } finally {
        setLoading(false);
      }
    });
  })(publicKey, serviceId, templateId);
</script>
<script>
  import "./index.js";
</script>
