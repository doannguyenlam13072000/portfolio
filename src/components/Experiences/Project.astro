---
const { project } = Astro.props;
---

<div class="timeline-content flex items-start relative">
  <div class="exp-text flex xl:gap-20 md:gap-10 gap-10 relative z-20">
    <div>
      <h1 class="text-headline text-2xl font-semibold">
        {project.title}
      </h1>
      {project.subtitle && (
        <p class="text-secondary text-base mt-1">{project.subtitle}</p>
      )}
      <p class="text-paragraph text-sm my-4">
        🗓️ {project.period}
      </p>
      <p class="text-secondary italic">Responsibilities:</p>
      <ul class="list-disc mx-5 mt-5 flex flex-col gap-4 text-white">
        {
          project.responsibilities.map((responsibility: unknown) => (
            <li>{responsibility}</li>
          ))
        }
      </ul>
    </div>
  </div>
</div>
